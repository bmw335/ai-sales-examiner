{
  "appName": "AI销售模拟考官",
  "appMode": "internal_summer_exam",
  "examCode": "2026SUMMER",
  "requireExamCode": false,
  "dataRetentionDays": 30,
  "questionRule": {
    "default": [
      { "type": "A", "count": 1, "label": "专业基础快答题" },
      { "type": "B", "count": 1, "label": "1V1场景模拟主考题" },
      { "type": "C", "count": 1, "label": "考官追加追问题" }
    ],
    "strategy": "random_even_distribution",
    "allowRetake": true,
    "allowManualTranscript": true,
    "allowLocalFallbackScore": true
  },
  "roles": [
    { "role": "candidate", "name": "销售被考核人", "permissions": ["take_exam"] },
    { "role": "examiner", "name": "考官/培训负责人", "permissions": ["view_reports", "review_scores", "export_reports"] },
    { "role": "admin", "name": "系统管理员", "permissions": ["manage_questions", "manage_exam_config", "manage_users", "export_all"] }
  ],
  "api": {
    "transcribe": "/api/transcribe",
    "score": "/api/score",
    "reports": "/api/reports"
  },
  "frontend": {
    "doubleClickRunnable": true,
    "staticServerRequired": false,
    "backendOptionalForPreview": true,
    "productionRequireHttpsForRecording": true
  }
}
